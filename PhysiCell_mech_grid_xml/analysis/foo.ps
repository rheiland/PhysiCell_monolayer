0 61(    def precompute\(self, steps: int, max_agents: int = 500\) -> None:)p
0 62(        """)p
0 63(        Run the full simulation up-front and store every frame's agent list.)p
0 64(        Required before calling interactive_viewer\(\).)p
1 1(        Args:)p
1 2(            steps:      Number of time steps to pre-compute.)p
1 3(            max_agents: Stop early if population exceeds this.)p
1 4(        """)p
1 5(        import copy)p
1 6(        print\(f"Pre-computing {steps} steps...", end=" ", flush=True\))p
