1 11(                f"t = {idx}   |   agents = {len\(agent_list\)}"  #   |   max gen =)p
1 12( {max_gen}")p
1 13(            \))p
1 15(            # pop_line.set_data\(all_times[:idx + 1], all_pops[:idx + 1]\))p
1 16(            # time_marker.set_xdata\([idx, idx]\))p
1 18(            # Update slider without triggering its callback)p
1 19(            slider.eventson = False)p
1 20(            slider.set_val\(idx\))p
1 21(            slider.eventson = True)p
1 23(            fig.canvas.draw_idle\(\))p
1 25(            # mpld3.save_html\(fig, 'index.html'\) # Save directly to an HTML file)p
1 29(        # ------------------------------------------------------------------ #)p
1 30(        # Button / slider callbacks)p
1 31(        # ------------------------------------------------------------------ #)p
1 32(        def on_back\(_event\):)p
1 33(            state["playing"] = False)p
1 34(            btn_play.label.set_text\(" Play"\))p
1 35(            _draw_frame\(state["frame"] - 1\))p
1 37(        def on_fwd\(_event\):)p
1 38(            state["playing"] = False)p
1 39(            btn_play.label.set_text\(" Play"\))p
1 40(            _draw_frame\(state["frame"] + 1\))p
1 42(        def on_play\(_event\):)p
1 43(            state["playing"] = not state["playing"])p
1 44(            btn_play.label.set_text\(" Pause" if state["playing"] else " Play"\))p
1 45(            fig.canvas.draw_idle\(\))p
1 47(        def on_slider\(val\):)p
1 48(            state["playing"] = False)p
1 49(            btn_play.label.set_text\(" Play"\))p
1 50(            _draw_frame\(int\(val\)\))p
1 52(        btn_back.on_clicked\(on_back\))p
1 53(        btn_fwd.on_clicked\(on_fwd\))p
1 54(        btn_play.on_clicked\(on_play\))p
1 55(        slider.on_changed\(on_slider\))p
1 57(        # ------------------------------------------------------------------ #)p
1 58(        # Timer-driven playback)p
1 59(        # ------------------------------------------------------------------ #)p
1 60(        def _tick\(_frame\):)p
1 61(            if state["playing"]:)p
1 62(                nxt = state["frame"] + 1)p
1 63(                if nxt >= n_frames:)p
1 64(                    state["playing"] = False)p
