1 14(    def grow\(self\) -> None:)p
1 15(        """Increase area by growth_rate for one time step.""")p
1 16(            #   -- may need to scale by dt here \(Dom\))p
1 17(        self.area += self.growth_rate)p
1 18(        self.time_step += 1)p
1 19(        # if self.time_step % 5 == 0:)p
1 21(    def should_divide\(self\) -> bool:)p
1 22(        """Return True if this agent has reached or exceeded its division area.")p
1 23("")p
1 24(        return self.area >= self.division_area)p
1 26(    def divide\(self, separation: float = 0.5, noise: float = 0.1\) -> tuple["Agen)p
1 27(t", "Agent"]:)p
1 28(        global max_ID)p
1 29(        """)p
1 30(        Divide this agent into two daughter agents.)p
1 32(        The daughters have 1/2 the area of the parent. One daughter remains in t)p
1 33(he parent's position;)p
1 34(        the other daughter is placed at a random position around the other, so t)p
1 35(hey just touch.)p
1 37(        Returns:)p
1 38(            A tuple of two new Agent instances \(daughter_1, daughter_2\).)p
1 39(        """)p
1 41(        daughter_area = self.area / 2)p
1 42(        daughter_radius = math.sqrt\(daughter_area/math.pi\))p
1 44(        max_ID += 1)p
1 46(        theta = random.random\(\) * 6.283185307179    # 2 * math.pi)p
1 47(        xvec = math.cos\(theta\) * daughter_radius * 2)p
1 48(        yvec = math.sin\(theta\) * daughter_radius * 2)p
1 50(        nr1 = random.normalvariate\(mu=2.0, sigma=0.4\)   # mean=2, stddev=0.4)p
1 51(        while nr1 < 0:)p
1 52(             nr1 = random.normalvariate\(mu=2.0, sigma=0.4\)   # mean=2, stddev=0.)p
1 53(4)p
1 55(        nr2 = random.normalvariate\(mu=2.0, sigma=0.4\)   # mean=2, stddev=0.4)p
1 56(        while nr2 < 0:)p
1 57(             nr2 = random.normalvariate\(mu=2.0, sigma=0.4\)   # mean=2, stddev=0.)p
1 58(4)p
1 60(        if daughter_split == 0:     # PhysiCell: daughter = parent x,y)p
1 61(            d1 = Agent\(x=self.x,      y=self.y,      vel_x=0, vel_y=0,)p
1 62(                    area=daughter_area, growth_rate=self.growth_rate,)p
1 63(                    division_area=78.54 * nr1, norm_rand=nr1, ID=self.ID\))p
1 64(            d2 = Agent\(x=self.x + xvec, y=self.y + yvec, vel_x=0, vel_y=0,)p
